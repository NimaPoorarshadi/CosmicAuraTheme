  "tokenColors": [
    {
      "settings": {
        "foreground": "#E0D8EC"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "markup.quote.markdown",
        "meta.diff",
        "meta.diff.header"
      ],
      "settings": {
        "foreground": "#6E5A7Ecc",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Text Color",
      "scope": [
        "variable",
        "text.html.derivative",
        "meta.property-name.css",
        "meta.property-list.css",
        "source.python",
        "constant.name.attribute.tag.jade",
        "punctuation.separator.key-value.js",
        "punctuation.definition.metadata.markdown",
        "punctuation.definition.string.end.markdown",
        "punctuation.definition.string.begin.markdown"
      ],
      "settings": {
        "foreground": "#E0D8EC"
      }
    },
    {
      "name": "Nebula Cyan \u2014 object keys, yaml, json, html entities",
      "scope": [
        "variable.other.object.access.cpp",
        "keyword.control.directive.include.cpp",
        "support.variable",
        "meta.object-literal.key.js",
        "entity.name.tag.yaml",
        "constant.character.entity.html",
        "source.css entity.name.tag.reference",
        "beginning.punctuation.definition.list.markdown",
        "source.css entity.other.attribute-name.parent-selector",
        "meta.structure.dictionary.json support.type.property-name"
      ],
      "settings": {
        "foreground": "#78DCE8"
      }
    },
    {
      "name": "Nebula Violet \u2014 numbers, attributes, object properties",
      "scope": [
        "markup.bold",
        "constant.numeric",
        "meta.group.regexp",
        "constant.other.php",
        "support.constant.ext.php",
        "constant.other.class.php",
        "support.constant.core.php",
        "fenced_code.block.language",
        "constant.other.caps.python",
        "entity.other.attribute-name",
        "support.type.exception.python",
        "source.css keyword.other.unit",
        "variable.other.object.property.js.jsx",
        "variable.other.object.js"
      ],
      "settings": {
        "foreground": "#AB9DF2"
      }
    },
    {
      "name": "Nebula Gold \u2014 functions, entity names, types",
      "scope": [
        "markup.list",
        "text.xml string",
        "support.function",
        "entity.name.function",
        "entity.name.type",
        "meta.at-rule.extend",
        "entity.other.inherited-class",
        "entity.other.keyframe-offset.css",
        "text.html.markdown string.quoted",
        "meta.function-call.generic.python",
        "meta.at-rule.extend support.constant",
        "entity.other.attribute-name.class.jade",
        "source.css entity.other.attribute-name",
        "text.xml punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#FFD866"
      }
    },
    {
      "name": "Nebula Pink \u2014 this, self, headings",
      "scope": [
        "markup.heading",
        "variable.language.this.js",
        "variable.language.special.self.python"
      ],
      "settings": {
        "foreground": "#FF6188"
      }
    },
    {
      "name": "Nebula Purple \u2014 HTML tags, template expressions, interpolation",
      "scope": [
        "punctuation.support.type.property-name.begin.json",
        "punctuation.support.type.property-name.end.json",
        "punctuation.definition.interpolation",
        "punctuation.section.embedded.end.php",
        "punctuation.section.embedded.end.ruby",
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.begin.ruby",
        "punctuation.definition.template-expression",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#C46BF0"
      }
    },
    {
      "name": "Nebula Rose \u2014 decorators, regexp, language constants",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "meta.decorator punctuation.decorator",
        "entity.name.function.decorator",
        "entity.name.function.decorator.python",
        "constant.language.python",
        "string.regexp",
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FF6188"
      }
    },
    {
      "name": "Nebula Keyword \u2014 keywords, storage",
      "scope": [
        "storage",
        "keyword",
        "meta.link",
        "meta.image",
        "markup.italic",
        "source.js support.type"
      ],
      "settings": {
        "foreground": "#C46BF0"
      }
    },
    {
      "name": "Nebula Operator \u2014 operators, constants, string punctuation",
      "scope": [
        "constant",
        "support.class",
        "keyword.operator",
        "support.constant",
        "text.html.markdown string",
        "source.css support.function",
        "source.php support.function",
        "support.function.magic.python",
        "entity.other.attribute-name.id",
        "punctuation.definition.string",
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FC9867"
      }
    },
    {
      "name": "Nebula Green \u2014 strings",
      "scope": [
        "string",
        "text.html.php string",
        "markup.inline.raw",
        "markup.inserted",
        "punctuation.definition.markdown",
        "text.html meta.embedded source.js string",
        "text.html.php punctuation.definition.string",
        "text.html meta.embedded source.js punctuation.definition.string",
        "text.html punctuation.definition.string",
        "text.html string"
      ],
      "settings": {
        "foreground": "#A9DC76"
      }
    },
    {
      "name": "Font Underline",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Font Italic",
      "scope": [
        "comment",
        "invalid",
        "keyword",
        "entity.other.attribute-name"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    }
  ]
}